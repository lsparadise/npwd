{
  "PhoneAsItem": {
    "enabled": true,
    "exportResource": "dependencies",
    "exportFunction": "hasPhone"
  },
  "general": {
    "useResourceIntegration": true,
    "toggleKey": "F5",
    "toggleCommand": "phone",
    "defaultLanguage": "fr",
    "phoneNumberFormat": "/(\\d{3})(\\d{4})/"
  },
  "database": {
    "useIdentifierPrefix": false,
    "playerTable": "characters",
    "identifierColumn": "id",
    "identifierType": "id",
    "profileQueries": false,
    "phoneNumberColumn": "phone"
  },
  "images": {
    "useWebhook": true
  },
  "disabledApps": ["BROWSER", "CALCULATOR", "MATCH", "TWITTER", "MARKETPLACE", "NOTES", "DARKCHAT"]
}
