{
  "PhoneAsItem": {
    "enabled": true,
    "exportResource": "dependencies",
    "exportFunction": "hasPhone"
  },
  "general": {
    "useResourceIntegration": true,
    "toggleKey": "F5",
    "toggleCommand": "phone",
    "defaultLanguage": "fr"
  },
  "profanityFilter": {
    "enabled": false,
    "badWords": []
  },
  "database": {
    "useIdentifierPrefix": false,
    "playerTable": "characters",
    "identifierColumn": "id",
    "identifierType": "id",
    "profileQueries": false,
    "phoneNumberColumn": "phone"
  },
  "images": {
    "url": "https://api.imgur.com/3/image",
    "type": "imgur",
    "imageEncoding": "jpg",
    "contentType": "multipart/form-data",
    "useContentType": true,
    "authorizationHeader": "Authorization",
    "authorizationPrefix": "Client-ID",
    "useAuthorization": true,
    "returnedDataIndexes": ["data", "link"]
  },
  "debug": {
    "level": "error",
    "enabled": true,
    "sentryEnabled": false
  },
  "defaultContacts": [],
  "disabledApps": [
    "BROWSER",
    "CALCULATOR",
    "MATCH",
    "TWITTER",
    "MARKETPLACE",
    "NOTES"
  ],
  "apps": ["pefcl"],
  "voiceMessage": {
    "enabled": false,
    "authorizationHeader": "PE-Secret",
    "url": "",
    "returnedDataIndexes": ["url"]
  }
}
