{
  "PhoneAsItem": {
    "enabled": true,
    "exportResource": "dependencies",
    "exportFunction": "hasPhone"
  },
  "general": {
    "useResourceIntegration": true,
    "toggleKey": "F5",
    "toggleCommand": "phone",
    "defaultLanguage": "fr",
    "phoneNumberFormat": "/(555)(\\d{4})/"
  },
  "database": {
    "useIdentifierPrefix": false,
    "playerTable": "characters",
    "identifierColumn": "player",
    "identifierType": "discord",
    "profileQueries": false,
    "phoneNumberColumn": "phone"
  },
  "images": {
    "url": "https://api.imgur.com/3/image",
    "type": "imgur",
    "imageEncoding": "jpg",
    "contentType": "multipart/form-data",
    "useContentType": true,
    "authorizationHeader": "Authorization",
    "authorizationPrefix": "Client-ID",
    "useAuthorization": true,
    "returnedDataIndexes": ["data", "link"]
  },
  "disabledApps": ["BROWSER", "CALCULATOR", "MATCH", "TWITTER", "MARKETPLACE", "NOTES", "DARKCHAT"]
}
